# Copy to .env.local for local development (never commit .env.local).
# In production, set these in Vercel -> Project -> Settings -> Environment Variables.

# Resend API key (resend.com -> API Keys -> Create API Key, "Sending access")
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=hello@volumes.cloud
